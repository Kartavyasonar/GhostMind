# ============================================================
#  GhostMind — Environment Configuration
#  Copy this to .env and fill in your keys
# ============================================================

# ── GEMINI (Free tier: 1,500 req/day per key, 15 req/min) ───
# Add as many keys as you have Google accounts.
# Each key is registered with BOTH gemini-2.0-flash AND gemini-1.5-flash,
# so 1 key = 3,000 free requests/day. 3 keys = 9,000 free requests/day.
#
# How to get free Gemini keys:
#   https://aistudio.google.com/app/apikey
#   (Create a new Google account for each extra key)

GEMINI_API_KEY=AIzaSy...your_first_key_here

# Optional extra keys (uncomment and fill as needed):
# GEMINI_API_KEY_2=AIzaSy...second_key
# GEMINI_API_KEY_3=AIzaSy...third_key
# GEMINI_API_KEY_4=AIzaSy...fourth_key
# GEMINI_API_KEY_5=AIzaSy...fifth_key

# ── OPENAI (Paid fallback) ───────────────────────────────────
# Only used if all Gemini keys are rate-limited.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── ANTHROPIC (Paid fallback) ────────────────────────────────
# Only used if all Gemini and OpenAI providers fail.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── OTHER SETTINGS (defaults are fine for local dev) ─────────
ENV=development
DATABASE_URL=sqlite+aiosqlite:///./ghostmind.db
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

EMBED_MODEL=all-MiniLM-L6-v2
EMBED_DIM=384

ARXIV_MAX_RESULTS=15

MEMRL_ALPHA=0.1
MEMRL_GAMMA=0.9
MEMRL_EPSILON=0.15

CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:5174"]
