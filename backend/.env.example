# ============================================================
#  GhostMind — Environment Configuration
#  Copy this file to .env and fill in your keys
#  cp .env.example .env
# ============================================================

# ── PRIMARY LLM: Groq (FREE, fast, no daily quota) ──────────
#
#  GET YOUR FREE KEY: https://console.groq.com
#  - 14,400 requests/day free
#  - ~30 requests/minute
#  - ~5 second response time
#  - No credit card required
#
#  This is the recommended and default primary provider.
#  If set, Groq is ALWAYS tried first before any other provider.
#
GROQ_API_KEY=gsk_...your_groq_key_here

# Groq model — llama-3.3-70b-versatile is the best free option
GROQ_MODEL=llama-3.3-70b-versatile


# ── FALLBACK LLM: Gemini (FREE, slower, daily quota) ────────
#
#  GET YOUR FREE KEY: https://aistudio.google.com/app/apikey
#  - 1,500 requests/day per key (free tier)
#  - 15 requests/minute per key
#  - Only used if Groq fails or is unavailable
#
#  Add up to 10 keys to increase daily capacity.
#  Leave blank if you only want to use Groq.
#
GEMINI_API_KEY=
# GEMINI_API_KEY_1=AIzaSy...second_key
# GEMINI_API_KEY_2=AIzaSy...third_key
# GEMINI_API_KEY_3=AIzaSy...fourth_key
# GEMINI_API_KEY_4=AIzaSy...fifth_key
# GEMINI_API_KEY_5=


# ── PAID FALLBACKS (optional) ───────────────────────────────
#
#  Only used if ALL free providers (Groq + Gemini) are exhausted.
#  Leave blank if you don't have paid API access.
#
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001


# ── DATABASE ─────────────────────────────────────────────────
#
#  SQLite is the default — no setup needed.
#  Switch to PostgreSQL for production or concurrent use.
#
DATABASE_URL=sqlite+aiosqlite:///./ghostmind.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/ghostmind


# ── LLM GENERATION SETTINGS ─────────────────────────────────
#
LLM_TEMPERATURE=0.2       # 0.0 = deterministic, 1.0 = creative
LLM_MAX_TOKENS=2048       # max tokens per generated answer


# ── EMBEDDINGS (local, no API key needed) ────────────────────
#
#  all-MiniLM-L6-v2 runs fully on CPU, no internet after first download.
#  Do not change unless you know what you're doing.
#
EMBED_MODEL=all-MiniLM-L6-v2
EMBED_DIM=384


# ── ARXIV INGESTION ──────────────────────────────────────────
#
#  Number of papers fetched from arXiv per query.
#  Higher = better retrieval coverage, slower first query.
#
ARXIV_MAX_RESULTS=15


# ── MEMRL — LEARNING SETTINGS ────────────────────────────────
#
#  These control how fast GhostMind learns from experience.
#
#  MEMRL_EPSILON — exploration rate
#    0.00 = always exploit best known strategy (pure memory)
#    0.15 = explore 15% of the time (recommended for normal use)
#    0.30 = explore 30% (useful when testing new strategies)
#    1.00 = always random (disables memory, for baseline testing)
#
#  MEMRL_ALPHA — learning rate
#    0.10 = slow, very stable Q-values
#    0.15 = recommended — visible movement, not noisy  ← default
#    0.30 = fast learning, more variance (good for demos)
#
#  MEMRL_GAMMA — discount factor
#    Not used in the current single-step TD implementation.
#    Kept for future multi-step RL extension.
#
MEMRL_EPSILON=0.15
MEMRL_ALPHA=0.15
MEMRL_GAMMA=0.9
MEMORY_MAX_TRIPLETS=10000


# ── SERVER ───────────────────────────────────────────────────
#
ENV=development
LOG_LEVEL=INFO

CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:5174"]


# ============================================================
#  DEMO CONFIGURATIONS
#
#  For maximum demo visibility (fast convergence):
#    MEMRL_ALPHA=0.30
#    MEMRL_EPSILON=0.15
#
#  After ~10 sessions, switch to pure exploitation:
#    MEMRL_EPSILON=0.00
#
#  To reset and start learning from scratch:
#    Delete ghostmind.db and restart the backend.
# ============================================================
